# Claude API — required for real triage/extraction (model: claude-opus-4-8).
# Without it the app runs in labeled mock mode (deterministic checks only).
ANTHROPIC_API_KEY=

# Supabase — OPTIONAL locally. If both are set, the app uses Supabase (what prod
# does); if unset, it uses a zero-setup in-memory store with the same seed data.
# NOTE: setting these locally makes `npm run dev` talk to the SAME project as prod
# (see HANDOFF.md section 5). Values live in the Vercel project env / Supabase dashboard.
# SUPABASE_URL=https://mjgedufhemlfwtqvxbet.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=            # server-side service role; never ships to the client

# Optional overrides:
# TRIAGE_MODEL=claude-opus-4-8
# MOCK_TRIAGE=1                         # force mock mode even with a key set
